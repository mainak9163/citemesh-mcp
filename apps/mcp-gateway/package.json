{
  "name": "@citemesh/mcp-gateway",
  "version": "0.1.0",
  "description": "MCP server gateway that exposes scholarly metadata tools to AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "citemesh-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@citemesh/contracts": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "pino": "^9.2.0",
    "undici": "^6.18.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
