{
  "name": "@citemesh/metadata-federator",
  "version": "0.1.0",
  "description": "Fastify service that queries Crossref and Wikidata, normalizes metadata, and caches responses",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@citemesh/contracts": "workspace:*",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "pino": "^9.2.0",
    "undici": "^6.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
