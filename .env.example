# ─── Service Ports ────────────────────────────────────────────────────────────
METADATA_FEDERATOR_PORT=3001
EXPORT_WORKER_PORT=3002

# ─── Internal Service URLs (used by mcp-gateway) ──────────────────────────────
METADATA_FEDERATOR_URL=http://localhost:3001
EXPORT_WORKER_URL=http://localhost:3002

# ─── SQLite Cache ─────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to metadata-federator working dir)
CACHE_DB_PATH=./cache.db

# Default TTL for cached API responses (in seconds)
CACHE_TTL_SECONDS=3600

# ─── External APIs ────────────────────────────────────────────────────────────
# Crossref Polite Pool: add your email for higher rate limits
# https://api.crossref.org/swagger-ui/index.html
CROSSREF_MAILTO=your-email@example.com

# Wikidata SPARQL endpoint (public, no auth required)
WIKIDATA_ENDPOINT=https://query.wikidata.org/sparql

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
